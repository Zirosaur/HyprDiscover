#!/usr/bin/env bash
# HyprDiscover launcher — single-instance enforcement

APP_DIR="${HYPRDISCOVER_DIR:-$HOME/.local/share/hyprdiscover}"
APP="$APP_DIR/hyprdiscover.py"

if [[ "$*" == *"--waybar"* ]]; then
    python3 "$APP" "$@"
    exit 0
fi

if pgrep -f "python3 $APP" >/dev/null 2>&1; then
    hyprctl dispatch focuswindow "class:^(com.hyprdiscover.app)$" 2>/dev/null || \
    hyprctl dispatch focuswindow "title:^(HyprDiscover)$" 2>/dev/null || true
else
    python3 "$APP" "$@"
fi
